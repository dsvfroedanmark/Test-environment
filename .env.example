# Database (Neon — use the pooled connection string)
DATABASE_URL="postgresql://neondb_owner:<password>@ep-<name>-pooler.<region>.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# App
DEFAULT_WORKSPACE_ID="default-workspace"

# Optional: Real API keys (not needed for mock mode)
# ANTHROPIC_API_KEY="sk-ant-..."
# INSTAGRAM_ACCESS_TOKEN="..."
# FACEBOOK_ACCESS_TOKEN="..."
